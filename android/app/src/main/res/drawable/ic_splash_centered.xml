<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon for Android 12+.
     The system applies a circular mask (264dp diameter on a 288dp canvas).
     We place the rounded-square app icon at 160dp so it fits fully
     inside the circle without any edge clipping. White background
     blends with the white splash screen. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item
        android:width="160dp"
        android:height="160dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_app_icon" />
    </item>
</layer-list>
